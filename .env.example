HETZNER_API_TOKEN=your_hetzner_cloud_api_token
ENCRYPTION_KEY=your_32_character_encryption_key_here
JWT_SECRET=your_jwt_secret_here

# For initial admin user creation
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately

# Optional: List of initial servers to monitor (can also be added via UI)
# format: ip,user,key_path
INITIAL_SERVERS=1.2.3.4,root,/path/to/key;5.6.7.8,root,/path/to/key

# Port for backend
PORT=3000

# Backblaze B2 Configuration (S3 Compatible)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=s3.us-east-005.backblazeb2.com
